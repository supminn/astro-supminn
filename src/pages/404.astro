---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | Supriya Minnasandram">
  <main class="section-shell grid min-h-screen place-items-center py-20">
    <section class="max-w-xl rounded-lg border bg-card p-8 text-center shadow-soft">
      <p class="text-sm font-semibold uppercase text-primary">404</p>
      <h1 class="mt-3 font-display text-4xl font-bold">Page not found</h1>
      <p class="mt-4 text-muted-foreground">
        This route is not part of the refreshed portfolio.
      </p>
      <a
        class="mt-6 inline-flex h-10 items-center justify-center rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
        href="/"
      >
        Back to home
      </a>
    </section>
  </main>
</BaseLayout>
