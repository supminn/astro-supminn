---
interface Props {
  to: string;
  label: string;
}

const { to, label } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content={`0; url=${to}`} http-equiv="refresh" />
    <meta name="robots" content="noindex" />
    <title>{label} | Supriya Minnasandram</title>
  </head>
  <body>
    <p>
      Redirecting to <a href={to}>{label}</a>.
    </p>
    <script is:inline define:vars={{ to }}>
      window.location.replace(to);
    </script>
  </body>
</html>
